    <div class="projects-grid" id="projects-grid"></div>
  </div>
</section>

<!-- SKILLS -->
<section id="skills">
  <div class="container">
    <div class="section-eyebrow">04 · Capabilities</div>
    <h2 class="section-title">Technical Skills</h2>
